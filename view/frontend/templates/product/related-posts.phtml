<?php

declare(strict_types=1);

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Magento\Framework\Escaper $escaper */

$title = (string) $block->getData('title');
?>
<div class="mageos-blog-related-posts">
    <?php if ($title !== ''): ?>
        <h3 class="mageos-blog-related-posts__title"><?= $escaper->escapeHtml($title); ?></h3>
    <?php endif; ?>
    <p class="mageos-blog-related-posts__placeholder">
        <?= $escaper->escapeHtml(__('Related posts for products — scoped ViewModel lands in v1.1.')); ?>
    </p>
</div>
