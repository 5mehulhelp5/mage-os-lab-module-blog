<?php

declare(strict_types=1);

/** @var \MageOS\Blog\Block\Author\View $block */
/** @var \Magento\Framework\Escaper $escaper */

use MageOS\Blog\ViewModel\Author\Detail as AuthorDetail;

/** @var AuthorDetail $viewModel */
$viewModel = $block->getData('view_model');
$author = $viewModel->getAuthor();
if ($author === null) {
    return;
}
$posts = $viewModel->getPosts();
$avatarUrl = $viewModel->getAvatarUrl();
$bio = $viewModel->getBio();
$email = $viewModel->getEmail();
$twitter = $viewModel->getTwitter();
$linkedin = $viewModel->getLinkedin();
$website = $viewModel->getWebsite();
?>
<div class="mageos-blog mageos-blog-container">
    <header class="mageos-blog-context">
        <?php if ($avatarUrl !== null): ?>
            <img class="mageos-blog-context__avatar"
                 src="<?= $escaper->escapeUrl($avatarUrl); ?>"
                 alt="<?= $escaper->escapeHtmlAttr($viewModel->getTitle()); ?>">
        <?php endif; ?>
        <h1 class="mageos-blog-context__title"><?= $escaper->escapeHtml($viewModel->getTitle()); ?></h1>
        <?php if ($bio !== null && $bio !== ''): ?>
            <div class="mageos-blog-context__description"><?= /** @noEscape */ $bio; ?></div>
        <?php endif; ?>
        <?php if ($email !== null || $twitter !== null || $linkedin !== null || $website !== null): ?>
            <div class="mageos-blog-share">
                <?php if ($email !== null && $email !== ''): ?>
                    <a href="mailto:<?= $escaper->escapeUrl($email); ?>"><?= $escaper->escapeHtml(__('Email')); ?></a>
                <?php endif; ?>
                <?php if ($twitter !== null && $twitter !== ''): ?>
                    <a href="<?= $escaper->escapeUrl($twitter); ?>" rel="noopener noreferrer" target="_blank">
                        <?= $escaper->escapeHtml(__('Twitter')); ?>
                    </a>
                <?php endif; ?>
                <?php if ($linkedin !== null && $linkedin !== ''): ?>
                    <a href="<?= $escaper->escapeUrl($linkedin); ?>" rel="noopener noreferrer" target="_blank">
                        <?= $escaper->escapeHtml(__('LinkedIn')); ?>
                    </a>
                <?php endif; ?>
                <?php if ($website !== null && $website !== ''): ?>
                    <a href="<?= $escaper->escapeUrl($website); ?>" rel="noopener noreferrer" target="_blank">
                        <?= $escaper->escapeHtml(__('Website')); ?>
                    </a>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </header>

    <?php if ($posts === []): ?>
        <p class="mageos-blog-empty"><?= $escaper->escapeHtml(__('No posts by this author yet.')); ?></p>
    <?php else: ?>
        <div class="mageos-blog-cards">
            <?php foreach ($posts as $post): ?>
                <?= $block->getLayout()
                    ->createBlock(\Magento\Framework\View\Element\Template::class)
                    ->setTemplate('MageOS_Blog::post/card.phtml')
                    ->setData('post', $post)
                    ->setData('view_model', $viewModel)
                    ->toHtml(); ?>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
