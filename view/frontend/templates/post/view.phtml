<?php

declare(strict_types=1);

/** @var \MageOS\Blog\Block\Post\View $block */
/** @var \Magento\Framework\Escaper $escaper */

use MageOS\Blog\ViewModel\Post\Detail as PostDetail;

/** @var PostDetail $viewModel */
$viewModel = $block->getData('view_model');
$post = $viewModel->getPost();
?>
<?php if ($post !== null): ?>
    <article class="mageos-blog-post">
        <header class="mageos-blog-post__header">
            <h1 class="mageos-blog-post__title"><?= $escaper->escapeHtml($viewModel->getTitle()); ?></h1>
            <?php $date = $viewModel->getFormattedPublishDate(); ?>
            <?php if ($date !== ''): ?>
                <time class="mageos-blog-post__date"><?= $escaper->escapeHtml($date); ?></time>
            <?php endif; ?>
        </header>

        <?php $img = $viewModel->getFeaturedImageUrl(); ?>
        <?php if ($img !== null): ?>
            <figure class="mageos-blog-post__featured-image">
                <img src="<?= $escaper->escapeUrl($img); ?>"
                     alt="<?= $escaper->escapeHtmlAttr($viewModel->getFeaturedImageAlt()); ?>">
            </figure>
        <?php endif; ?>

        <div class="mageos-blog-post__content">
            <?= /** @noEscape */ $viewModel->getContent() ?? ''; ?>
        </div>
    </article>
<?php endif; ?>
