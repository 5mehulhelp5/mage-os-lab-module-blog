<?php

declare(strict_types=1);

/** @var \MageOS\Blog\Block\Widget\PostList $block */
/** @var \Magento\Framework\Escaper $escaper */

$posts = $block->getPosts();
?>
<div class="mageos-blog-widget mageos-blog-widget--post-list">
    <?php if (count($posts) === 0): ?>
        <p class="mageos-blog-widget__empty"><?= $escaper->escapeHtml(__('No posts match this filter.')); ?></p>
    <?php else: ?>
        <ul class="mageos-blog-widget__items">
            <?php foreach ($posts as $post): ?>
                <li class="mageos-blog-widget__item">
                    <a href="<?= $escaper->escapeUrl($block->getPostUrl($post)); ?>">
                        <?= $escaper->escapeHtml($post->getTitle()); ?>
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>
    <?php endif; ?>
</div>
