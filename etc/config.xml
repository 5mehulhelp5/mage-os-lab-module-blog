<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <mageos_blog>
            <general>
                <enabled>0</enabled>
            </general>
            <post>
                <posts_per_page>10</posts_per_page>
                <default_robots>INDEX,FOLLOW</default_robots>
            </post>
            <sidebar>
                <search_enabled>1</search_enabled>
                <search_sort_order>10</search_sort_order>
                <recent_posts_enabled>1</recent_posts_enabled>
                <recent_posts_sort_order>20</recent_posts_sort_order>
                <recent_posts_count>5</recent_posts_count>
                <category_list_enabled>1</category_list_enabled>
                <category_list_sort_order>30</category_list_sort_order>
                <tag_cloud_enabled>1</tag_cloud_enabled>
                <tag_cloud_sort_order>40</tag_cloud_sort_order>
                <archive_enabled>1</archive_enabled>
                <archive_sort_order>50</archive_sort_order>
            </sidebar>
            <seo>
                <og_default_type>article</og_default_type>
                <json_ld_enabled>1</json_ld_enabled>
                <twitter_site></twitter_site>
            </seo>
            <sitemap>
                <post>
                    <enabled>1</enabled>
                    <frequency>daily</frequency>
                    <priority>0.5</priority>
                </post>
                <category>
                    <enabled>1</enabled>
                    <frequency>weekly</frequency>
                    <priority>0.4</priority>
                </category>
                <tag>
                    <enabled>1</enabled>
                    <frequency>weekly</frequency>
                    <priority>0.3</priority>
                </tag>
            </sitemap>
            <social>
                <networks>facebook,x,linkedin,reddit,email</networks>
            </social>
            <rss>
                <enabled>1</enabled>
                <limit>20</limit>
            </rss>
        </mageos_blog>
    </default>
</config>
